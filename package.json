{
  "name": "lekto-cli",
  "version": "0.1.0",
  "description": "Terminal-based reader for EPUB, DOCX, FB2, Markdown, and plain text",
  "bin": {
    "lekto": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build ./src/cli.ts --target bun --outfile lekto-cli",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "mammoth": "^1.7.0",
    "marked": "^9.1.0",
    "jszip": "^3.10.1",
    "node-html-parser": "^6.1.0",
    "commander": "^11.1.0",
    "crypto": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "latest",
    "typescript": "^5.3.0"
  }
}
